# AutoCAD 平面图 - 方案A：水墨江南
# 绍兴越城区文旅小镇
# 比例：1:500
# 单位：米

# 用地边界
LINE 0,0 120,0 120,80 20,90 0,50 CLOSE

# 中央水街（宽6m）
LINE 30,20 90,20
LINE 30,26 90,26
TEXT 60,23 "中央水街 宽6m"

# 功能分区
# 1. 文化展示区（西北）
RECTANGLE 10,50 35,75
TEXT 22,62 "文化展示中心\n建筑面积：3000㎡\n2层坡屋顶"

# 2. 商业街区（东北）
RECTANGLE 75,50 110,75
TEXT 92,62 "特色商业街区\n建筑面积：5000㎡\n1-2层连廊"

# 3. 餐饮休闲（东南）
RECTANGLE 75,10 110,35
TEXT 92,22 "餐饮休闲区\n建筑面积：4000㎡\n滨水餐饮"

# 4. 民宿院落（西南）
RECTANGLE 10,10 45,35
TEXT 27,22 "精品民宿\n建筑面积：6000㎡\n院落式布局"

# 5. 滨水绿地（南侧）
RECTANGLE 5,0 115,10
TEXT 60,5 "滨水景观带\n宽度：10m"

# 景观节点
CIRCLE 30,40 3
TEXT 30,40 "石桥1"

CIRCLE 60,40 3
TEXT 60,40 "石桥2"

CIRCLE 90,40 3
TEXT 90,40 "石桥3"

# 指北针
INSERT NORTH_ARROW 110,85

# 比例尺
LINE 10,-10 60,-10
TEXT 35,-15 "0    50m"

# 图框
RECTANGLE -10,-20 130,100

# 标题
TEXT 60,95 "绍兴文旅小镇平面图"
TEXT 60,92 "方案A：水墨江南风格"
TEXT 60,89 "比例：1:500"

# 经济技术指标
TEXT 5,-30 "用地面积：33,333㎡"
TEXT 5,-33 "总建筑面积：26,000㎡"
TEXT 5,-36 "容积率：0.78"
TEXT 5,-39 "建筑密度：38%"
TEXT 5,-42 "绿地率：28%"
