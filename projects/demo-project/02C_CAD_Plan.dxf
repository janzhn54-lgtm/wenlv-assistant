# AutoCAD 平面图 - 方案C：越国风华
# 绍兴越城区文旅小镇
# 比例：1:500
# 单位：米

# 用地边界
LINE 0,0 120,0 120,80 20,90 0,50 CLOSE

# 一核：越文化展示核（中心）
CIRCLE 60,45 15
TEXT 60,45 "越文化演艺中心\n建筑面积：4000㎡\n圆形穹顶"

# 两轴
# 东西文化轴
LINE 15,45 105,45
TEXT 60,48 "东西文化轴"

# 南北商业轴
LINE 60,10 60,80
TEXT 63,45 "南北商业轴"

# 三区
# 演艺区（西侧）
RECTANGLE 5,30 35,60
TEXT 20,45 "越剧演艺区\n古戏台+现代剧场"

# 手作区（东侧）
RECTANGLE 85,30 115,60
TEXT 100,45 "非遗手作区\n黄酒/印染/竹编"

# 美食区（南侧）
RECTANGLE 35,5 85,30
TEXT 60,17 "越式美食街\n黄酒宴/绍兴菜"

# 越王台（制高点）
RECTANGLE 55,65 65,75
TEXT 60,70 "越王台\n观景塔\n高15m"

# 曲水流觞（水景）
ARC 60,25 50,35 70,35
TEXT 60,30 "曲水流觞"

# 指北针
INSERT NORTH_ARROW 110,85

# 比例尺
LINE 10,-10 60,-10
TEXT 35,-15 "0    50m"

# 标题
TEXT 60,95 "绍兴文旅小镇平面图"
TEXT 60,92 "方案C：越国风华风格"
TEXT 60,89 "比例：1:500"
